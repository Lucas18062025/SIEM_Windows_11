# ═══════════════════════════════════════════════════════════
# SIEM Personal v4.0 — Variables de entorno
# ═══════════════════════════════════════════════════════════
# INSTRUCCIONES:
#   1. Copiá este archivo como .env:    copy .env.example .env
#   2. Completá con tus datos reales
#   3. NUNCA subas .env a GitHub (ya está en .gitignore)
# ═══════════════════════════════════════════════════════════

# Telegram Bot (obtener de @BotFather en Telegram)
TELEGRAM_TOKEN=tu_token_de_botfather_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# NVD API Key (https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=tu_api_key_de_nvd_aqui

# Contacto Operador SIEM
CONTACT_NOMBRE=Tu Nombre
CONTACT_EMAIL=tu.email@ejemplo.com
CONTACT_PORTFOLIO=https://tu-portfolio.com
CONTACT_LINKEDIN=https://linkedin.com/in/tu-perfil
